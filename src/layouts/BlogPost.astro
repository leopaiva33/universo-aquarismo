---
import Layout from './Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
  readTime?: number;
  heroImage?: string;
  slug: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category = 'Aquarismo',
  tags = [],
  readTime = 5,
  heroImage,
  slug,
} = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const formattedUpdated = updatedDate?.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const siteUrl = 'https://universoaquarista.com';
const postUrl = `${siteUrl}/blog/${slug}`;

// Artigo pilar do cluster (mesma categoria): concentra a autoridade da categoria
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const pillarPost = allPosts.find(p => p.data.category === category && p.data.featured && p.slug !== slug);

// Artigos relacionados: mesma categoria primeiro, depois tags em comum
const relatedPosts = allPosts
  .filter(p => p.slug !== slug)
  .map(p => {
    const sharedTags = p.data.tags.filter(t => tags.includes(t)).length;
    const sameCategory = p.data.category === category ? 1 : 0;
    return { post: p, score: sameCategory * 10 + sharedTags };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map(({ post }) => post);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: heroImage ? `${siteUrl}${heroImage}` : `${siteUrl}/og-default.jpg`,
      datePublished: pubDate.toISOString(),
      dateModified: (updatedDate ?? pubDate).toISOString(),
      inLanguage: 'pt-BR',
      author: { '@type': 'Organization', name: 'Universo Aquarismo' },
      publisher: {
        '@type': 'Organization',
        name: 'Universo Aquarismo',
        logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
      },
      mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Início', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: 'Artigos', item: `${siteUrl}/blog` },
        { '@type': 'ListItem', position: 3, name: title, item: postUrl },
      ],
    },
  ],
};
---

<Layout title={title} description={description} type="article">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="blog-post">
    <!-- Hero do post -->
    <header class="post-header">
      {heroImage && (
        <div class="post-hero-image">
          <img src={heroImage} alt={title} loading="eager" />
        </div>
      )}
      <div class="container--narrow">
        <div class="post-category">{category}</div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>📅 {formattedDate}</time>
          {updatedDate && (
            <span>🔄 Atualizado em {formattedUpdated}</span>
          )}
          <span>⏱ {readTime} min de leitura</span>
        </div>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => <span class="tag">#{tag}</span>)}
          </div>
        )}
      </div>
    </header>

    <!-- Guia pilar do cluster: concentra autoridade e evita canibalização de palavra-chave -->
    {pillarPost && (
      <div class="pillar-callout container--narrow">
        📌 Guia completo sobre {category}: <a href={`/blog/${pillarPost.slug}`}>{pillarPost.data.title}</a>
      </div>
    )}

    <!-- Adsense slot (topo do artigo) -->
    <!--
    <div class="ad-slot container--narrow">
      <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXX" data-ad-slot="XXXX" data-ad-format="auto"></ins>
    </div>
    -->

    <!-- Conteúdo -->
    <div class="post-content container--narrow prose">
      <slot />
    </div>

    <!-- Adsense slot (fim do artigo) -->
    <!--
    <div class="ad-slot container--narrow">
      <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-XXXX" data-ad-slot="XXXX" data-ad-format="auto"></ins>
    </div>
    -->

    <!-- Artigos relacionados -->
    {relatedPosts.length > 0 && (
      <section class="related container--narrow">
        <h2 class="related-title">📖 Continue lendo</h2>
        <div class="related-grid">
          {relatedPosts.map(post => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              pubDate={post.data.pubDate}
              category={post.data.category}
              readTime={post.data.readTime}
              heroImage={post.data.heroImage}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Footer do post -->
    <footer class="post-footer container--narrow">
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map(tag => <span class="tag">#{tag}</span>)}
        </div>
      )}
      <a href="/blog" class="back-link">← Voltar para todos os artigos</a>
    </footer>
  </article>
</Layout>

<style>
.post-hero-image {
  width: 100%;
  max-height: 420px;
  overflow: hidden;
  margin-bottom: 2rem;
}

.post-hero-image img {
  width: 100%;
  height: 420px;
  object-fit: cover;
  display: block;
}

.post-header {
  background: linear-gradient(180deg, var(--color-surface) 0%, transparent 100%);
  border-bottom: 1px solid var(--color-border);
  padding-block: 3rem 2.5rem;
  margin-bottom: 2.5rem;
}

.post-category {
  display: inline-block;
  padding: 0.3rem 0.9rem;
  background: rgba(0, 212, 255, 0.1);
  border: 1px solid rgba(0, 212, 255, 0.25);
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--color-primary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 1.25rem;
}

.post-title {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 800;
  line-height: 1.2;
  color: var(--color-heading);
  margin-bottom: 1rem;
}

.post-description {
  font-size: 1.1rem;
  color: var(--color-muted);
  line-height: 1.7;
  margin-bottom: 1.5rem;
  max-width: 60ch;
}

.post-meta {
  display: flex;
  gap: 1.25rem;
  font-size: 0.85rem;
  color: var(--color-muted);
  flex-wrap: wrap;
  margin-bottom: 1rem;
}

.post-tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.tag {
  padding: 0.25rem 0.7rem;
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  border-radius: 999px;
  font-size: 0.78rem;
  color: var(--color-muted);
}

.pillar-callout {
  background: rgba(0, 212, 255, 0.08);
  border: 1px solid rgba(0, 212, 255, 0.25);
  border-radius: var(--radius-sm);
  padding: 0.85rem 1.1rem;
  font-size: 0.9rem;
  color: var(--color-muted);
  margin-bottom: 2rem;
}

.pillar-callout a {
  color: var(--color-primary);
  font-weight: 600;
  text-decoration: none;
}

.pillar-callout a:hover { color: var(--color-secondary); }

.post-content {
  padding-block: 0.5rem 2rem;
}

.ad-slot {
  margin-block: 2rem;
  background: var(--color-surface-2);
  border: 1px dashed var(--color-border);
  border-radius: var(--radius-sm);
  padding: 1rem;
  text-align: center;
  min-height: 100px;
}

.related {
  padding-block: 2.5rem 1rem;
  border-top: 1px solid var(--color-border);
}

.related-title {
  font-size: 1.3rem;
  font-weight: 800;
  margin-bottom: 1.25rem;
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1.25rem;
}

.post-footer {
  padding-block: 2rem 1rem;
  border-top: 1px solid var(--color-border);
  margin-top: 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}

.back-link {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-primary);
  text-decoration: none;
  transition: color 0.2s;
}

.back-link:hover { color: var(--color-secondary); }
</style>
