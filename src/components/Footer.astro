---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">🐠 Universo Aquarismo</span>
      <p class="footer-desc">
        Guias completos, dicas de especialistas e tudo o que você precisa saber sobre iluminação para aquário e aquarismo em geral.
      </p>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <h4>Conteúdo</h4>
        <a href="/blog">Todos os Artigos</a>
        <a href="/categoria/iluminacao-led">Iluminação LED</a>
        <a href="/categoria/plantas-aquaticas">Plantas Aquáticas</a>
        <a href="/categoria/peixes">Peixes</a>
      </div>
      <div class="footer-col">
        <h4>Sobre</h4>
        <a href="/sobre">Sobre o Blog</a>
        <a href="/contato">Contato</a>
        <a href="/politica-privacidade">Privacidade</a>
        <a href="/rss.xml">RSS Feed</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© {year} Universo Aquarismo. Todos os direitos reservados.</p>
      <p class="disclaimer">
        Este site participa de programas de afiliados. Ao comprar via nossos links, podemos ganhar uma comissão sem custo extra para você.
      </p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
  margin-top: 5rem;
}

.footer-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  padding-block: 3rem;
}

.footer-logo {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--color-heading);
  display: block;
  margin-bottom: 0.75rem;
}

.footer-desc {
  color: var(--color-muted);
  font-size: 0.9rem;
  line-height: 1.6;
  max-width: 32ch;
}

.footer-links {
  display: flex;
  gap: 3rem;
  justify-content: flex-end;
}

.footer-col {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.footer-col h4 {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-primary);
  margin-bottom: 0.5rem;
}

.footer-col a {
  color: var(--color-muted);
  font-size: 0.9rem;
  transition: color 0.2s;
  text-decoration: none;
}

.footer-col a:hover { color: var(--color-primary); }

.footer-bottom {
  border-top: 1px solid var(--color-border);
  padding-block: 1.25rem;
}

.footer-bottom .container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.footer-bottom p {
  color: var(--color-muted);
  font-size: 0.8rem;
}

.disclaimer {
  max-width: 50ch;
  text-align: right;
  opacity: 0.7;
}

@media (max-width: 640px) {
  .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
  .footer-links { justify-content: flex-start; }
  .footer-bottom .container { flex-direction: column; align-items: flex-start; }
  .disclaimer { text-align: left; }
}
</style>
