---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Tudo sobre Iluminação para Aquário',
  subtitle = 'Guias completos, reviews e dicas para deixar seu aquário incrível com a iluminação certa.',
} = Astro.props;
---

<section class="hero">
  <div class="hero-bg">
    <div class="bubble" style="--x:15%;--y:70%;--size:180px;--delay:0s"></div>
    <div class="bubble" style="--x:80%;--y:40%;--size:120px;--delay:1.5s"></div>
    <div class="bubble" style="--x:50%;--y:85%;--size:80px;--delay:3s"></div>
    <div class="bubble" style="--x:30%;--y:20%;--size:60px;--delay:0.8s"></div>
    <div class="bubble" style="--x:70%;--y:75%;--size:100px;--delay:2.2s"></div>
  </div>
  <div class="container hero-content">
    <div class="hero-badge">💡 Blog de Aquarismo</div>
    <h1 class="hero-title">{title}</h1>
    <p class="hero-subtitle">{subtitle}</p>
    <div class="hero-actions">
      <a href="/blog" class="btn btn-primary">Ver Todos os Artigos</a>
      <a href="#featured" class="btn btn-ghost">Destaques ↓</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">50+</span>
        <span class="stat-label">Artigos</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">100%</span>
        <span class="stat-label">Gratuito</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">PT-BR</span>
        <span class="stat-label">Em Português</span>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  padding-block: clamp(3rem, 8vw, 6rem);
  overflow: hidden;
  text-align: center;
}

.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.bubble {
  position: absolute;
  left: var(--x);
  top: var(--y);
  width: var(--size);
  height: var(--size);
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(0, 212, 255, 0.12), rgba(0, 212, 255, 0.02));
  border: 1px solid rgba(0, 212, 255, 0.08);
  animation: float 8s ease-in-out infinite;
  animation-delay: var(--delay);
  transform: translate(-50%, -50%);
}

@keyframes float {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.6; }
  50% { transform: translate(-50%, -60%) scale(1.05); opacity: 1; }
}

.hero-content {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-block;
  padding: 0.35rem 1rem;
  background: rgba(0, 212, 255, 0.1);
  border: 1px solid rgba(0, 212, 255, 0.25);
  border-radius: 999px;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 1.5rem;
  letter-spacing: 0.05em;
}

.hero-title {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800;
  line-height: 1.15;
  color: var(--color-heading);
  max-width: 16ch;
  margin-inline: auto;
  margin-bottom: 1.25rem;
  background: linear-gradient(135deg, #fff 0%, #00d4ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  color: var(--color-muted);
  font-size: clamp(1rem, 2vw, 1.2rem);
  max-width: 50ch;
  margin-inline: auto;
  margin-bottom: 2.5rem;
  line-height: 1.7;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.75rem;
  border-radius: var(--radius-md);
  font-size: 0.95rem;
  font-weight: 600;
  transition: all 0.2s;
  text-decoration: none;
}

.btn-primary {
  background: var(--color-primary);
  color: #0a0e1a;
}

.btn-primary:hover {
  background: var(--color-secondary);
  color: #0a0e1a;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0, 212, 255, 0.3);
}

.btn-ghost {
  color: var(--color-muted);
  border: 1px solid var(--color-border);
}

.btn-ghost:hover {
  color: var(--color-primary);
  border-color: var(--color-primary);
}

.hero-stats {
  display: inline-flex;
  align-items: center;
  gap: 2rem;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 1rem 2rem;
}

.stat { text-align: center; }

.stat-value {
  display: block;
  font-size: 1.25rem;
  font-weight: 800;
  color: var(--color-primary);
}

.stat-label {
  font-size: 0.75rem;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.stat-divider {
  width: 1px;
  height: 2.5rem;
  background: var(--color-border);
}

@media (max-width: 480px) {
  .hero-stats { gap: 1.25rem; padding: 0.85rem 1.25rem; }
}
</style>
